---
import { ongoingProjects } from '../../data/projects';
---

<section id="lab" class="py-32 px-6 relative z-10 bg-white/5 backdrop-blur-sm border-t border-white/40">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-24">
      <p class="section-eyebrow mx-auto">Lab</p>
      <h2 class="text-5xl md:text-6xl font-black gradient-text mt-6 mb-6">Applied AI Lab</h2>
      <p class="text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed mb-8">
        Live experiments where I test product ideas in automation, analytics, and AI-assisted workflows
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative order-2 lg:order-1">
        <div class="glass rounded-[2rem] p-12 max-w-lg mx-auto lg:ml-auto transition-all duration-700">
          <div class="relative mb-8">
            <div class="absolute inset-0 bg-gradient-to-br from-teal-200/30 via-sky-200/20 to-orange-200/25 rounded-3xl blur-xl"></div>
            <div class="relative glass rounded-3xl p-8 text-center border border-white/50">
              <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-3xl flex items-center justify-center text-xl font-black tracking-[0.18em] text-white shadow-2xl">
                LAB
              </div>
              <h3 class="text-2xl font-bold gradient-text mb-4">Active Experiments</h3>
              <div class="space-y-2 text-slate-600 text-sm">
                <div class="flex items-center justify-center space-x-2">
                  <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                  <span>WhatsApp Automation</span>
                </div>
                <div class="flex items-center justify-center space-x-2">
                  <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" style="animation-delay: 0.2s;"></div>
                  <span>Document Intelligence</span>
                </div>
                <div class="flex items-center justify-center space-x-2">
                  <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" style="animation-delay: 0.4s;"></div>
                  <span>Dashboard Prototypes</span>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200 rounded-2xl p-6 backdrop-blur-sm">
            <p class="text-sm font-semibold text-orange-800 mb-2 flex items-center">
              <span class="w-5 h-5 bg-orange-500 rounded-full flex items-center justify-center text-[10px] mr-3 text-white">i</span>
              Side Initiative
            </p>
            <p class="text-orange-900/80 text-sm leading-relaxed">
              This is a <strong>learning lab for experimentation</strong>, not a full-time startup. It helps me bridge academic concepts with production-ready systems.
            </p>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2 space-y-8 max-w-xl lg:max-w-2xl">
        <div class="glass p-10 rounded-3xl border-l-8 border-teal-500 transition-all duration-500">
          <p class="text-xl md:text-2xl text-slate-800 leading-relaxed mb-8">
            Alongside my learning and job preparation, I maintain a <span class="gradient-text font-bold">small AI product lab</span> where I experiment with applied AI concepts through real-world automation and product ideas.
          </p>
          
          <div class="grid md:grid-cols-2 gap-6 text-slate-600">
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl flex items-center justify-center text-[11px] font-black mt-0.5 flex-shrink-0 text-white">LP</div>
                <div>
                  <h4 class="font-bold text-lg text-slate-900 mb-1">Learning-by-Building</h4>
                  <p class="text-sm">Testing ideas through complete systems</p>
                </div>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-xl flex items-center justify-center text-[11px] font-black mt-0.5 flex-shrink-0 text-white">PF</div>
                <div>
                  <h4 class="font-bold text-lg text-slate-900 mb-1">Practical Focus</h4>
                  <p class="text-sm">Real-world use cases over theory</p>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-gradient-to-br from-orange-500 to-amber-500 rounded-xl flex items-center justify-center text-[11px] font-black mt-0.5 flex-shrink-0 text-white">PR</div>
                <div>
                  <h4 class="font-bold text-lg text-slate-900 mb-1">Production Ready</h4>
                  <p class="text-sm">APIs, dashboards, deployment</p>
                </div>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-8 h-8 bg-gradient-to-br from-rose-500 to-orange-500 rounded-xl flex items-center justify-center text-[11px] font-black mt-0.5 flex-shrink-0 text-white">BV</div>
                <div>
                  <h4 class="font-bold text-lg text-slate-900 mb-1">Business Value</h4>
                  <p class="text-sm">Solving SMB automation problems</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="text-center pt-8">
          <p class="text-lg text-slate-600 mb-6 italic font-medium max-w-lg mx-auto">
            "These projects help me bridge the gap between <span class="gradient-text">academic concepts</span> and <span class="gradient-text">production-ready systems</span>."
          </p>
          <a href="https://sushvinailabs.vercel.app/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-3 px-8 py-4 glass rounded-3xl font-semibold text-lg text-slate-800 hover:-translate-y-0.5 transition-all duration-300">
            <span>Visit AI Product Lab</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>

        <div class="mt-16">
          <div class="flex items-end justify-between gap-4 mb-8">
            <div>
              <h3 class="text-3xl md:text-4xl font-black text-slate-900 mb-2">Ongoing Projects</h3>
              <p class="text-slate-600 text-lg max-w-2xl leading-relaxed">Work in progress, shipped as live experiments.</p>
            </div>
            <div class="w-20 h-1 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full"></div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            {ongoingProjects.map((project) => (
              <article class="glass rounded-3xl p-6 border border-white/10 hover:-translate-y-0.5 transition-all duration-300 overflow-hidden">
                <div class={`relative overflow-hidden rounded-2xl h-40 mb-5 bg-gradient-to-br ${project.accent} border border-white/30`}>
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.22),transparent_42%)]"></div>
                  <div class="relative h-full p-5 flex items-end justify-between">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/75 mb-2">{project.platform}</p>
                      <div class="text-5xl font-black text-white/95 leading-none">{project.monogram}</div>
                    </div>
                    <span class="px-3 py-1 rounded-full text-xs font-semibold bg-white/15 text-white/90 border border-white/20 backdrop-blur-sm">{project.status}</span>
                  </div>
                </div>

                <div class="flex items-start justify-between gap-4 mb-4">
                  <div>
                    <h3 class="text-2xl font-bold text-slate-900">{project.title}</h3>
                  </div>
                </div>

                <p class="text-slate-600 leading-relaxed">{project.description}</p>

                <div class="flex flex-wrap gap-2 mt-5">
                  {project.tags.map((tag) => (
                    <span class="px-3 py-1 bg-white/70 rounded-lg text-xs font-semibold text-slate-700 border border-slate-200">{tag}</span>
                  ))}
                </div>

                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 mt-6 text-emerald-700 hover:text-slate-900 font-semibold transition-all duration-300">
                  <span>Open Project</span>
                  <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
