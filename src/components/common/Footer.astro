---
const currentYear = new Date().getFullYear();
---

<footer class="glass py-12 px-6 border-t border-white/40 backdrop-blur-xl mt-24">
  <div class="max-w-6xl mx-auto text-center">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 mb-8">
      <div class="flex items-center space-x-3">
        <div class="w-12 h-12 glass rounded-2xl p-1 shadow-xl">
          <img src="/images/profile.jpg" alt="Vinod M" class="w-full h-full rounded-xl object-cover" />
        </div>
        <div>
          <h3 class="text-2xl font-black gradient-text">Vinod M</h3>
          <p class="text-slate-500 text-sm">Data Analytics Developer</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-6 justify-center md:justify-end">
        <a href="#home" class="text-slate-500 hover:text-slate-950 hover:underline transition-all duration-300">Home</a>
        <a href="#projects" class="text-slate-500 hover:text-slate-950 hover:underline transition-all duration-300">Projects</a>
        <a href="#contact" class="text-slate-500 hover:text-slate-950 hover:underline transition-all duration-300">Contact</a>
        <a href="/resume/Vinod_M_Premium_Resume.pdf" class="text-slate-500 hover:text-slate-950 hover:underline transition-all duration-300">Premium Resume</a>
        <a href="/resume/Vinod_M_ATS_Resume.pdf" class="text-slate-500 hover:text-slate-950 hover:underline transition-all duration-300">ATS Resume</a>
      </div>
    </div>

    <div class="border-t border-slate-200 pt-8 text-slate-500 text-sm">
      <p>&copy; {currentYear} Vinod M. Built with <span class="gradient-text font-semibold">Astro</span> and <span class="gradient-text font-semibold">Tailwind CSS</span>.</p>
      <p class="mt-2">Hootgalli, Ilavala Hobli, Karnataka, India</p>
    </div>
  </div>
</footer>
