---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { navItems } from '../data/nav';
import { socialLinks } from '../data/social-links';
import '../styles/global.css';
import '../styles/animations.css';

const { title = "Vinod M - Data Analyst | Business Insights & Dashboards", description = "Data Analyst focused on SQL, Python, and BI dashboards to drive business decisions." } = Astro.props;
const siteUrl = 'https://www.vinod-ai.me/';
const ogImage = '/images/profile.jpg';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Data Analyst, SQL, Power BI, Streamlit, Dashboards, KPI, Python, Business Intelligence, Analytics, Vinod M" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Vinod M Portfolio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/jpg+xml" href="/images/profile.jpg" />
    
    <!-- Global Script -->
    <script src="/scripts/global.js" is:inline></script>
    
    <ClientRouter />
  </head>
  <body class="relative">
    <!-- Particles Container -->
    <div id="particles" class="fixed inset-0 pointer-events-none z-0"></div>
    
    <Navbar {navItems} />
    <main>
      <slot />
    </main>
    <Footer {socialLinks} />

    <!-- 📱 WHATSAPP FLOATING BUTTON -->
     <a href={`https://wa.me/${socialLinks.whatsapp}`} class="fixed bottom-8 right-8 z-50 glass w-16 h-16 rounded-3xl shadow-2xl hover:scale-110 transition-all duration-300 group flex items-center justify-center text-3xl" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      💬
    </a>
    
    <script>
      // Mobile Menu Toggle
      document.addEventListener('DOMContentLoaded', () => {
        const mobileBtn = document.getElementById('mobile-menu');
        const mobileMenu = document.getElementById('mobile-menu-items');
        
        if (mobileBtn && mobileMenu) {
          mobileBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>