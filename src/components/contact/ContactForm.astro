---
import { socialLinks } from '../../data/social-links';
---

<section id="contact" class="py-32 px-6 relative z-10 bg-white/5 border-t border-white/40">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-24">
      <p class="section-eyebrow mx-auto">Contact</p>
      <h2 class="text-5xl md:text-6xl font-black gradient-text mt-6 mb-6">Let's Connect</h2>
      <p class="text-xl md:text-2xl text-slate-600 max-w-2xl mx-auto leading-relaxed mb-8">
        I am actively looking for <span class="gradient-text font-semibold">data analytics, BI, and applied AI opportunities</span> where I can deliver production-ready work.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="glass rounded-[2rem] p-10 md:p-12 border-white/10 backdrop-blur-xl">
          <h3 class="text-3xl font-bold gradient-text mb-8 text-center">Get In Touch</h3>
          
          <form class="space-y-6" id="contact-form">
            <div>
              <label class="block text-slate-700 font-semibold mb-3">Full Name</label>
              <input 
                type="text" 
                name="name" 
                required
                class="w-full glass px-6 py-4 rounded-2xl text-slate-800 placeholder-slate-400 border border-slate-200 focus:border-teal-500 focus:outline-none transition-all duration-300 text-lg"
                placeholder="Vinod M"
              />
            </div>

            <div>
              <label class="block text-slate-700 font-semibold mb-3">Email Address</label>
              <input 
                type="email" 
                name="email" 
                required
                class="w-full glass px-6 py-4 rounded-2xl text-slate-800 placeholder-slate-400 border border-slate-200 focus:border-teal-500 focus:outline-none transition-all duration-300 text-lg"
                placeholder="your-email@example.com"
              />
            </div>

            <div>
              <label class="block text-slate-700 font-semibold mb-3">Message</label>
              <textarea 
                name="message" 
                rows="5" 
                required
                class="w-full glass px-6 py-4 rounded-2xl text-slate-800 placeholder-slate-400 border border-slate-200 focus:border-teal-500 focus:outline-none transition-all duration-300 resize-vertical text-lg"
                placeholder="Tell me about the opportunity or how I can contribute..."
              ></textarea>
            </div>

            <button 
              type="submit"
              class="w-full gradient-border px-8 py-6 rounded-3xl text-xl font-bold text-slate-950 hover:-translate-y-0.5 transition-all duration-300"
            >
              Send Message
              <svg class="inline ml-2 w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
            </button>
          </form>

          <div id="form-success" class="hidden mt-6 p-6 rounded-3xl bg-emerald-500/20 border border-emerald-400/40 text-center">
            <div class="text-2xl mb-4 text-emerald-800">OK</div>
            <p class="text-emerald-900 text-lg font-semibold">Message sent successfully!</p>
            <p class="text-emerald-800 text-sm mt-2">I'll get back to you within 24 hours.</p>
          </div>
        </div>
      </div>

      <div class="space-y-8">
        <div class="glass rounded-[2rem] p-8 md:p-10 backdrop-blur-xl hover:-translate-y-0.5 transition-all duration-500">
          <h3 class="text-2xl font-bold gradient-text mb-8 text-center">Contact Information</h3>
          
          <div class="space-y-6">
            <div class="flex items-center space-x-4 p-4 glass rounded-2xl border-l-4 border-teal-500 transition-all duration-300">
              <div class="w-12 h-12 glass rounded-xl flex items-center justify-center text-sm font-black tracking-[0.18em] shadow-md text-teal-800">EM</div>
              <div>
                <p class="text-slate-500 font-semibold text-sm uppercase tracking-[0.18em]">Email</p>
                <a href={`mailto:${socialLinks.email}`} class="text-lg font-bold gradient-text transition-colors">{socialLinks.email}</a>
              </div>
            </div>

            <div class="flex items-center space-x-4 p-4 glass rounded-2xl border-l-4 border-slate-500 transition-all duration-300">
              <div class="w-12 h-12 glass rounded-xl flex items-center justify-center text-sm font-black tracking-[0.18em] shadow-md text-slate-800">GH</div>
              <div>
                <p class="text-slate-500 font-semibold text-sm uppercase tracking-[0.18em]">GitHub</p>
                <a href={socialLinks.github} target="_blank" class="text-lg font-bold gradient-text transition-colors">github.com/Vinodvinum</a>
              </div>
            </div>

            <div class="flex items-center space-x-4 p-4 glass rounded-2xl border-l-4 border-blue-500 transition-all duration-300">
              <div class="w-12 h-12 glass rounded-xl flex items-center justify-center text-sm font-black tracking-[0.18em] shadow-md text-blue-800">LI</div>
              <div>
                <p class="text-slate-500 font-semibold text-sm uppercase tracking-[0.18em]">LinkedIn</p>
                <a href={socialLinks.linkedin} target="_blank" class="text-lg font-bold gradient-text transition-colors">linkedin.com/in/vinod-m-b830061ba</a>
              </div>
            </div>

            <div class="flex items-center space-x-4 p-4 glass rounded-2xl border-l-4 border-emerald-500 transition-all duration-300">
              <div class="w-12 h-12 glass rounded-xl flex items-center justify-center text-sm font-black tracking-[0.18em] shadow-md bg-gradient-to-br from-emerald-500 to-teal-500 text-white">WA</div>
              <div>
                <p class="text-slate-500 font-semibold text-sm uppercase tracking-[0.18em]">WhatsApp</p>
                <a href={`https://wa.me/${socialLinks.whatsapp}`} target="_blank" class="text-lg font-bold text-emerald-700 hover:text-emerald-800 transition-colors">+91 {socialLinks.whatsapp}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const target = e.target as HTMLFormElement;
      const successMsg = document.getElementById('form-success') as HTMLElement;
      const submitBtn = target.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (submitBtn) {
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'Sending...';
        submitBtn.disabled = true;
        
        setTimeout(() => {
          if (successMsg) successMsg.classList.remove('hidden');
          target.reset();
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
          setTimeout(() => {
            if (successMsg) successMsg.classList.add('hidden');
          }, 5000);
        }, 1500);
      }
    });
  }
</script>
