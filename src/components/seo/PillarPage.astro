---
import { buildArticleIdeasForPillar, type PillarPage as PillarPageData } from '../../data/seo';

const { pillar } = Astro.props as { pillar: PillarPageData };
const articleIdeas = buildArticleIdeasForPillar(pillar);
---

<section class="min-h-screen pt-32 pb-20 px-6 relative z-10">
  <div class="max-w-7xl mx-auto">
    <header class="max-w-4xl mx-auto text-center mb-16">
      <p class="text-sm md:text-base tracking-[0.28em] uppercase text-cyan-200/80">Pillar Page</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-black gradient-text leading-tight">{pillar.title}</h1>
      <p class="mt-4 text-lg md:text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">{pillar.subtitle}</p>
      <p class="mt-6 text-base md:text-lg text-white/75 max-w-3xl mx-auto leading-relaxed">{pillar.intro}</p>
    </header>

    <div class="grid lg:grid-cols-[1.4fr_0.9fr] gap-8 items-start mb-14">
      <article class="glass rounded-[2rem] p-8 md:p-10 border-white/10 shadow-2xl shadow-black/20">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Why this pillar matters</h2>
        <p class="text-white/80 text-lg leading-relaxed mb-6">{pillar.description}</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="glass rounded-2xl p-5 border-white/10 bg-white/5">
            <p class="text-xs uppercase tracking-[0.24em] text-white/50 mb-2">Audience</p>
            <p class="text-white/85 leading-relaxed">{pillar.audience}</p>
          </div>
          <div class="glass rounded-2xl p-5 border-white/10 bg-white/5">
            <p class="text-xs uppercase tracking-[0.24em] text-white/50 mb-2">Search intent</p>
            <p class="text-white/85 leading-relaxed">This page is built to help users and Google connect Vinod M with a specific technology domain, supported by real projects and visible proof.</p>
          </div>
        </div>
      </article>

      <aside class="glass rounded-[2rem] p-8 border-white/10 shadow-2xl shadow-black/20">
        <h2 class="text-2xl font-bold text-white mb-5">Proof points</h2>
        <ul class="space-y-3 text-white/80">
          {pillar.proofPoints.map((point) => (
            <li class="flex gap-3">
              <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-cyan-300"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    <section class="mb-16">
      <div class="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-black gradient-text">Focus areas</h2>
          <p class="text-white/70 mt-2">The core topics that define this pillar and reinforce topical authority.</p>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {pillar.focusAreas.map((area) => (
          <div class="glass rounded-2xl p-5 border-white/10 hover:border-cyan-300/40 transition-all duration-300">
            <p class="text-white font-semibold">{area}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <div class="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-black gradient-text">Supporting pages</h2>
          <p class="text-white/70 mt-2">Internal links that help users move from the pillar to proof, contact, and related content.</p>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {pillar.internalLinks.map((link) => (
          <a href={link.href} class="glass rounded-2xl p-5 border-white/10 hover:border-fuchsia-300/40 hover:scale-[1.02] transition-all duration-300 block">
            <h3 class="text-xl font-bold text-white mb-2">{link.label}</h3>
            <p class="text-white/70 leading-relaxed">{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <div class="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-black gradient-text">SEO article ideas</h2>
          <p class="text-white/70 mt-2">Each pillar ships with a curated set of long-tail content ideas.</p>
        </div>
        <p class="text-white/50 text-sm uppercase tracking-[0.24em]">{articleIdeas.length} ideas</p>
      </div>
      <ol class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {articleIdeas.map((idea, index) => (
          <li class="glass rounded-2xl p-5 border-white/10 text-white/80 leading-relaxed">
            <span class="inline-flex text-xs uppercase tracking-[0.28em] text-cyan-200/70 mb-2">{String(index + 1).padStart(2, '0')}</span>
            <p>{idea}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="mb-14">
      <div class="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-black gradient-text">FAQ</h2>
          <p class="text-white/70 mt-2">Short answers that support natural-language search and on-page clarity.</p>
        </div>
      </div>
      <div class="grid gap-4">
        {pillar.faq.map((entry) => (
          <details class="glass rounded-2xl p-5 border-white/10">
            <summary class="cursor-pointer list-none text-white font-semibold text-lg">{entry.question}</summary>
            <p class="mt-3 text-white/75 leading-relaxed">{entry.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <div class="text-center glass rounded-[2rem] p-8 border-white/10">
      <p class="text-white/80 mb-4">Need this expertise on a project or role?</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/#contact" class="gradient-border glass px-6 py-3 rounded-2xl font-semibold text-white hover:scale-105 transition-all duration-300">Contact Vinod M</a>
        <a href="/featured" class="glass px-6 py-3 rounded-2xl font-semibold text-white/90 border border-white/20 hover:scale-105 transition-all duration-300">View projects</a>
      </div>
    </div>
  </div>
</section>