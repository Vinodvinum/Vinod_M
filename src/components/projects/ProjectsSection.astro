---
import { completedProjects, ongoingProjects } from '../../data/projects';
import type { ProjectCategory } from '../../data/projects';

const flagshipAnalytics = completedProjects.filter((project) =>
  ['GRS Fantasy Park MIS Command Center', 'AI Financial Analytics Dashboard', 'Operational KPI Dashboard'].includes(project.title)
);

const categorySections: Array<{ id: ProjectCategory; description: string }> = [
  {
    id: 'Analytics & Dashboards',
    description: 'KPI dashboards, MIS products, and decision support systems built for real operations.'
  },
  {
    id: 'Websites & Platforms',
    description: 'Full websites and deployed product platforms.'
  },
  {
    id: 'AI Automation & Chatbots',
    description: 'Conversational and workflow automation projects.'
  },
  {
    id: 'Utilities & Media',
    description: 'Utility-focused tools and media-oriented projects.'
  },
  {
    id: 'Computer Vision',
    description: 'Vision and detection systems built with ML pipelines.'
  }
];

const getProjectsByCategory = (category: ProjectCategory) => completedProjects.filter((project) => project.category === category);
---

<section id="projects" class="py-24 md:py-32 px-4 md:px-6 relative z-10 bg-gradient-to-b from-white/5 to-transparent backdrop-blur-sm">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14 md:mb-24">
      <p class="section-eyebrow mx-auto">Projects</p>
      <h2 class="text-4xl md:text-6xl font-black gradient-text mt-6 mb-5 md:mb-6">Flagged Work</h2>
      <p class="text-base md:text-2xl text-slate-600 max-w-2xl mx-auto leading-relaxed px-2">
        Live deployments, flagship analytics builds, and selected AI systems
      </p>
    </div>

    <div class="grid xl:grid-cols-3 gap-6 mb-16">
      {flagshipAnalytics.map((project) => (
        <article class="gradient-border rounded-[2rem] p-6 md:p-7">
          <div class={`relative overflow-hidden rounded-[1.6rem] h-44 mb-6 bg-gradient-to-br ${project.accent} border border-white/40`}>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.28),transparent_42%)]"></div>
            <div class="relative h-full p-5 flex items-end justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.22em] text-white/80 mb-2">{project.platform}</p>
                <div class="text-5xl font-black text-white/95 leading-none">{project.monogram}</div>
              </div>
              <span class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white/95 border border-white/20 backdrop-blur-sm">
                Flagship
              </span>
            </div>
          </div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-orange-700">Analytics Highlight</p>
          <h3 class="mt-3 text-2xl font-black text-slate-950">{project.title}</h3>
          <p class="mt-3 text-slate-600 leading-relaxed text-sm md:text-base">{project.description}</p>
          <div class="flex flex-wrap gap-2 mt-5">
            {project.tags.map((tag) => (
              <span class="px-3 py-1 bg-white/70 rounded-lg text-xs font-semibold text-slate-700 border border-slate-200">
                {tag}
              </span>
            ))}
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-6">
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="gradient-border px-4 py-3 rounded-2xl font-semibold text-sm transition-all duration-300 text-center text-slate-950">
                Live Demo
              </a>
            )}
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-slate-700 hover:text-slate-950 transition-all duration-300 text-center">
                GitHub
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    {categorySections.map((section) => {
      const projects = getProjectsByCategory(section.id);

      if (projects.length === 0) {
        return null;
      }

      return (
        <div class="mb-14 md:mb-20 last:mb-0">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 md:gap-4 mb-6 md:mb-8">
            <div>
              <h3 class="text-2xl md:text-4xl font-black text-slate-900 mb-2">{section.id}</h3>
              <p class="text-slate-600 text-sm md:text-lg max-w-2xl leading-relaxed">{section.description}</p>
            </div>
            <div class="w-20 h-1 bg-gradient-to-r from-teal-500 to-orange-500 rounded-full"></div>
          </div>

          <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5 md:gap-8">
            {projects.map((project) => (
              <article class="group glass rounded-[2rem] p-4 md:p-6 hover:-translate-y-1 transition-all duration-500 overflow-hidden">
                <div class={`relative overflow-hidden rounded-[1.5rem] h-44 mb-6 bg-gradient-to-br ${project.accent} border border-white/30`}>
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.22),transparent_42%)]"></div>
                  <div class="relative h-full p-5 flex items-end justify-between">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/75 mb-2">{project.platform}</p>
                      <div class="text-5xl font-black text-white/95 leading-none">{project.monogram}</div>
                    </div>
                    <span class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold bg-white/15 text-white/90 border border-white/20 backdrop-blur-sm">
                      {project.status}
                    </span>
                  </div>
                </div>

                <div class="flex items-start justify-between gap-4 mb-4">
                  <h4 class="text-xl md:text-2xl font-bold text-slate-900 leading-tight">{project.title}</h4>
                </div>

                <p class="text-slate-600 leading-relaxed text-sm md:text-base">{project.description}</p>

                <div class="flex flex-wrap gap-2 mt-6">
                  {project.tags.map((tag) => (
                    <span class="px-3 py-1 bg-white/70 rounded-lg text-xs font-semibold text-slate-700 border border-slate-200 transition-all duration-300">
                      {tag}
                    </span>
                  ))}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-7">
                  {project.liveUrl && (
                    <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="gradient-border px-4 py-3 rounded-2xl font-semibold text-sm transition-all duration-300 text-center text-slate-950">
                      Live Demo
                    </a>
                  )}
                  {project.githubUrl && (
                    <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-slate-700 hover:text-slate-950 border border-slate-200 transition-all duration-300 text-center">
                      GitHub
                    </a>
                  )}
                  {project.publicationUrl && (
                    <a href={project.publicationUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-teal-800 border border-teal-700/10 transition-all duration-300 text-center">
                      Publication
                    </a>
                  )}
                  {project.certificateUrl && (
                    <a href={project.certificateUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-emerald-800 border border-emerald-700/10 transition-all duration-300 text-center">
                      Certificate
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      );
    })}

    <div class="glass mt-16 rounded-[2rem] p-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-teal-700">Ongoing</p>
          <h3 class="mt-2 text-3xl font-black text-slate-950">Current Build Lab</h3>
          <p class="mt-3 max-w-2xl text-slate-600">
            Live experiments where I continue testing product ideas in analytics and AI automation.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 w-full lg:max-w-xl">
          {ongoingProjects.map((project) => (
            <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="glass rounded-[1.5rem] p-5 hover:-translate-y-0.5 transition-all duration-300">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{project.platform}</p>
                  <h4 class="mt-2 text-lg font-black text-slate-900">{project.title}</h4>
                </div>
                <span class="text-sm font-bold text-teal-700">{project.monogram}</span>
              </div>
              <p class="mt-3 text-sm text-slate-600">{project.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
