---
const NAME = 'Vinod M';
const TITLE = 'Data Analytics Developer';
const ONE_LINER = 'Building KPI dashboards, ETL pipelines, and analytics systems that help teams make faster decisions.';
---

<section id="home" class="min-h-screen flex items-center justify-center px-6 pt-28 pb-16 relative z-10 overflow-hidden">
  <div class="absolute top-20 right-0 h-80 w-80 rounded-full bg-orange-300/20 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 h-72 w-72 rounded-full bg-teal-300/20 blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto grid lg:grid-cols-[1.15fr_0.85fr] gap-12 items-center">
    <div class="space-y-8">
      <div class="space-y-5">
        <p class="section-eyebrow">Analytics . BI . Applied AI</p>
        <a href="https://medhakshatech.in/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-700/10 bg-emerald-50 text-emerald-800 text-xs md:text-sm font-semibold hover:bg-emerald-100 transition-all duration-300">
          Co-founder, Medhaksha Technology
        </a>

        <h1 class="text-5xl md:text-6xl xl:text-7xl font-extrabold leading-[0.95] tracking-tight">
          <span class="block text-slate-900">{NAME}</span>
          <span class="block gradient-text mt-3">
            <span id="typewriter" class="overflow-hidden border-r-4 border-teal-600 pr-4" style="width: 0; white-space: nowrap;">{TITLE}</span>
          </span>
        </h1>

        <p class="text-lg md:text-2xl text-slate-700 font-medium max-w-2xl leading-relaxed">
          {ONE_LINER}
        </p>

        <p class="text-base md:text-lg text-slate-600 max-w-2xl leading-relaxed">
          Data Analytics Developer with 1+ year of experience delivering KPI dashboards, reporting automation, and data quality workflows. I improved annotation data accuracy by 25 percent at VisionVerse and built analytics products that management teams use in day-to-day operations.
        </p>

        <p class="text-base md:text-lg text-slate-500 max-w-2xl leading-relaxed">
          My recent work spans ETL with Python and SQL, live Streamlit dashboards, and applied NLP pipelines including the internship I completed at Qikk Automation Technology (Rexsatronics), Koorgally.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="#projects" class="gradient-border px-7 py-3.5 rounded-2xl text-base md:text-lg font-semibold text-slate-950 hover:-translate-y-0.5 transition-all duration-300">
          View Projects
        </a>
        <a href="/resume/Vinod_M_Premium_Resume.pdf" class="glass px-7 py-3.5 rounded-2xl text-base md:text-lg font-semibold text-slate-800 hover:-translate-y-0.5 transition-all duration-300">
          Premium Resume
        </a>
        <a href="/resume/Vinod_M_ATS_Resume.pdf" class="glass px-7 py-3.5 rounded-2xl text-base md:text-lg font-semibold text-slate-800 hover:-translate-y-0.5 transition-all duration-300">
          ATS Resume
        </a>
        <a href="#contact" class="px-7 py-3.5 rounded-2xl text-base md:text-lg font-semibold text-teal-800 hover:text-teal-950 hover:bg-teal-50 border border-teal-700/15 transition-all duration-300">
          Contact Me
        </a>
      </div>

      <div class="grid sm:grid-cols-4 gap-4 max-w-4xl">
        <div class="metric-card px-5 py-4 text-center">
          <p class="text-3xl font-black gradient-text">25%</p>
          <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500">Accuracy Lift</p>
        </div>
        <div class="metric-card px-5 py-4 text-center">
          <p class="text-3xl font-black gradient-text">30%</p>
          <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500">Reporting Saved</p>
        </div>
        <div class="metric-card px-5 py-4 text-center">
          <p class="text-3xl font-black gradient-text">92%</p>
          <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500">NER Accuracy</p>
        </div>
        <div class="metric-card px-5 py-4 text-center">
          <p class="text-3xl font-black gradient-text">17+</p>
          <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500">Projects</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -inset-8 rounded-[2.5rem] bg-gradient-to-tr from-teal-200/45 via-amber-100/60 to-orange-200/45 blur-3xl opacity-90"></div>
      <div class="relative glass rounded-[2.5rem] p-4 md:p-6 shadow-[0_30px_90px_rgba(127,89,43,0.16)] animate-[float_6s_ease-in-out_infinite]">
        <div class="relative overflow-hidden rounded-[2rem] border border-white/60 bg-[linear-gradient(180deg,rgba(255,254,250,0.92),rgba(247,239,227,0.9))]">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(15,118,110,0.14),transparent_32%),radial-gradient(circle_at_80%_80%,rgba(194,65,12,0.16),transparent_32%)]"></div>
          <div class="absolute top-4 left-4 z-20 px-3 py-1 rounded-full text-xs font-semibold text-teal-800 border border-teal-700/10 bg-white/75">
            Flagship analytics work
          </div>
          <img src="/images/profile.jpg" alt={NAME} class="relative z-10 w-full h-full object-cover" />
          <div class="absolute bottom-4 left-4 right-4 z-20 glass rounded-2xl px-4 py-3 flex items-center justify-between gap-3 text-xs md:text-sm">
            <div>
              <p class="text-slate-500">Current Focus</p>
              <p class="text-slate-900 font-semibold">ETL . KPI Dashboards . BI Reporting</p>
            </div>
            <span class="px-3 py-1 rounded-full bg-emerald-50 text-emerald-800 text-xs font-semibold border border-emerald-700/10">
              Open to Opportunities
            </span>
          </div>
        </div>
      </div>

      <div class="glass mt-6 rounded-[2rem] p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-orange-700">Highlighted Project</p>
            <h3 class="mt-2 text-2xl font-black text-slate-950">GRS Fantasy Park MIS Command Center</h3>
          </div>
          <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-orange-700">Live</span>
        </div>
        <p class="mt-4 text-sm md:text-base text-slate-600 leading-relaxed">
          Multi-module analytics dashboard featuring revenue tracking, footfall analytics, demand forecasting, anomaly alerts, and automated KPI reporting.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold text-white">Streamlit</span>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 border border-slate-200">Pandas</span>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 border border-slate-200">Forecasting</span>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 border border-slate-200">Anomaly Detection</span>
        </div>
        <a href="https://grsdashboard.streamlit.app/" target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-teal-800 hover:text-teal-950">
          Open live dashboard
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
// @ts-nocheck
  const phrases = ['Data Analytics Developer', 'BI Engineer', 'Data Analyst', 'Applied AI Builder'];
  let i = 0;
  let j = 0;
  let forward = true;

  function typeWriter() {
    const el = document.getElementById('typewriter');
    if (!el) return;

    if (forward) {
      el.textContent = phrases[i].slice(0, j);
      j++;
      if (j > phrases[i].length) {
        forward = false;
        setTimeout(typeWriter, 1000);
      } else {
        setTimeout(typeWriter, 100);
      }
    } else {
      el.textContent = phrases[i].slice(0, j);
      j--;
      if (j < 0) {
        forward = true;
        i = (i + 1) % phrases.length;
        setTimeout(typeWriter, 500);
      } else {
        setTimeout(typeWriter, 50);
      }
    }
  }

  typeWriter();

  function createParticle() {
    const particle = document.createElement('div');
    particle.className = 'particle';
    particle.style.left = Math.random() * 100 + '%';
    particle.style.top = Math.random() * 100 + '%';
    particle.style.animationDelay = Math.random() * 20 + 's';
    particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
    const particlesContainer = document.getElementById('particles');
    if (particlesContainer) {
      particlesContainer.appendChild(particle);
      setTimeout(() => particle.remove(), 20000);
    }
  }

  setInterval(createParticle, 300);

  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const href = anchor.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });
  });
</script>
