---
// @ts-nocheck
import { navItems } from '../../data/nav';
---

<nav class="glass fixed top-0 w-full z-50 px-6 py-4 backdrop-blur-2xl border-b border-white/40">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-teal-500/50 to-transparent"></div>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center space-x-3 group p-2 -m-2 rounded-2xl backdrop-blur-sm hover:bg-white/50 transition-all duration-300">
      <div class="w-12 h-12 glass rounded-xl p-1 shadow-xl group-hover:scale-105 transition-all duration-500">
        <img src="/images/profile.jpg" alt="Vinod M" class="w-full h-full rounded-xl object-cover" />
      </div>
      <div>
        <span class="text-xl md:text-2xl font-black gradient-text tracking-tight">Vinod M</span>
        <span class="block text-xs md:text-sm text-slate-600 font-bold tracking-[0.18em] uppercase">Data Analytics Developer</span>
      </div>
    </a>

    <div class="hidden md:flex items-center space-x-1">
      {navItems.map((item) => (
        <a 
          href={item.href}
          class="group relative px-5 py-3 text-base font-semibold text-slate-600 hover:text-slate-950 transition-all duration-300"
        >
          {item.label}
          <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-teal-500 to-orange-500 group-hover:w-3/4 transition-all duration-300 origin-center"></span>
        </a>
      ))}
    </div>

    <button id="mobile-menu" class="md:hidden glass p-4 rounded-2xl hover:-translate-y-0.5 transition-all duration-300 shadow-xl">
      <svg class="w-6 h-6 text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div class="md:hidden mt-3 px-1 flex items-center justify-between gap-2">
    <a href="#home" class="glass flex-1 text-center py-2 rounded-xl text-sm font-semibold text-slate-700 hover:text-slate-950">Home</a>
    <a href="#projects" class="glass flex-1 text-center py-2 rounded-xl text-sm font-semibold text-slate-700 hover:text-slate-950">Projects</a>
    <a href="#contact" class="glass flex-1 text-center py-2 rounded-xl text-sm font-semibold text-slate-700 hover:text-slate-950">Contact</a>
  </div>

  <div id="mobile-menu-items" class="md:hidden hidden mt-4 mx-6 glass p-6 rounded-3xl backdrop-blur-xl border-white/20 space-y-4">
    {navItems.map((item) => (
      <a 
        href={item.href}
        class="block px-6 py-4 text-lg font-semibold text-slate-700 hover:text-slate-950 hover:bg-white/60 rounded-2xl transition-all duration-300 border-l-4 border-transparent hover:border-teal-500"
        onclick="document.getElementById('mobile-menu-items').classList.add('hidden')"
      >
        {item.label}
      </a>
    ))}
  </div>
</nav>
