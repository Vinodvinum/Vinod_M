---
import { socialLinks } from '../../data/social-links';
const currentYear = new Date().getFullYear();
---

<footer class="glass py-12 px-6 border-t border-white/10 backdrop-blur-xl mt-24">
  <div class="max-w-6xl mx-auto text-center">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 mb-8">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        
        <div class="w-12 h-12 glass rounded-2xl p-1 shadow-xl">
          <img src="/images/profile.jpg" alt="Vinod M, also known as Vinu" class="w-full h-full rounded-xl object-cover" />
        </div>
        <div>
          <h3 class="text-2xl font-black gradient-text">Vinod M</h3>
          <p class="text-white/60 text-sm">AI, Analytics & Software Engineering</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-wrap gap-6 justify-center md:justify-end">
        <a href="/" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Home</a>
        <a href="/expertise" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Expertise</a>
        <a href="/blog" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Blog</a>
        <a href="/featured" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Featured</a>
        <a href="/#contact" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Contact</a>
        <a href="/resume/Vinod_M_Premium_Resume.pdf" class="text-white/70 hover:text-white hover:underline transition-all duration-300">Premium Resume</a>
        <a href="/resume/Vinod_M_ATS_Resume.pdf" class="text-white/70 hover:text-white hover:underline transition-all duration-300">ATS Resume</a>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-8">
      <a href={socialLinks.website} target="_blank" rel="noopener noreferrer" class="glass px-4 py-2 rounded-full text-white/80 hover:text-white border border-white/10">Website</a>
      <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="glass px-4 py-2 rounded-full text-white/80 hover:text-white border border-white/10">GitHub</a>
      <a href={socialLinks.githubReadme} target="_blank" rel="noopener noreferrer" class="glass px-4 py-2 rounded-full text-white/80 hover:text-white border border-white/10">GitHub README</a>
      <a href={socialLinks.linkedin} target="_blank" rel="noopener noreferrer" class="glass px-4 py-2 rounded-full text-white/80 hover:text-white border border-white/10">LinkedIn</a>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-8 text-white/40 text-sm">
      <p>© {currentYear} Vinod M. Built with <span class="gradient-text font-semibold">Astro</span> & <span class="gradient-text font-semibold">Tailwind CSS</span>.</p>
      <p class="mt-2">Hootgalli, Ilavala Hobli, Karnataka, India</p>
    </div>
  </div>
</footer>
