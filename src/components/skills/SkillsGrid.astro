---
const skillsData = [
  {
    category: 'Python & Analytics',
    items: [
      'Python for ETL and reporting automation',
      'Pandas, NumPy, Plotly, Matplotlib',
      'Exploratory analysis and KPI design'
    ],
    icon: 'PY',
    color: 'from-teal-500 to-cyan-500',
    proof: ['Pandas', 'NumPy', 'Plotly']
  },
  {
    category: 'SQL & ETL',
    items: [
      'Validation queries, joins, CTEs, aggregations',
      'Extract, transform, validate, and load workflows',
      'Root cause analysis for data quality issues'
    ],
    icon: 'SQL',
    color: 'from-slate-700 to-slate-900',
    proof: ['SQL Audits', 'Data Validation', 'ETL']
  },
  {
    category: 'Dashboarding & BI',
    items: [
      'Streamlit and Power BI dashboard delivery',
      'Operational KPI tracking and business reporting',
      'Weekly report automation with Google Sheets API'
    ],
    icon: 'BI',
    color: 'from-orange-500 to-amber-500',
    proof: ['Streamlit', 'Power BI', 'KPI Dashboards']
  },
  {
    category: 'Applied AI',
    items: [
      'NER and transformer-based extraction pipelines',
      'Computer vision with YOLOv5 and tracking',
      'Git, GitHub, deployment, and production handoff'
    ],
    icon: 'AI',
    color: 'from-rose-500 to-orange-500',
    proof: ['Transformers', 'YOLOv5', 'GitHub']
  }
];
---

<section id="skills" class="py-32 px-6 relative z-10 bg-white/3 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-24">
      <p class="section-eyebrow mx-auto">Skills</p>
      <h2 class="text-5xl md:text-6xl font-black gradient-text mt-6 mb-6">Analytics Stack</h2>
      <p class="text-xl md:text-2xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Tools and methods I use to ship dashboards, data pipelines, and AI-assisted workflows
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-8">
      {skillsData.map((skill) => (
        <div class="group glass rounded-[2rem] p-8 hover:-translate-y-1 transition-all duration-500 cursor-pointer relative overflow-hidden">
          <div class={`absolute inset-0 bg-gradient-to-br ${skill.color} opacity-[0.08] blur-xl group-hover:opacity-[0.16] transition-opacity duration-500`}></div>
          <div class="relative z-10">
            <div class={`w-20 h-20 mx-auto mb-8 rounded-[1.6rem] flex items-center justify-center text-2xl font-black text-white bg-gradient-to-br ${skill.color} shadow-lg`}>
              <span>{skill.icon}</span>
            </div>
            
            <h3 class="text-2xl md:text-3xl font-black text-slate-900 mb-8 text-center">
              {skill.category}
            </h3>
            
            <div class="mb-8">
              <span class="text-slate-700 font-semibold block mb-3">Proof from shipped work</span>
              <div class="flex flex-wrap gap-2">
                {skill.proof.map((tool) => (
                  <span class="px-3 py-1 rounded-xl text-xs font-semibold bg-white/70 border border-slate-200 text-slate-700">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          
            <ul class="space-y-3">
              {skill.items.map((item) => (
                <li class="flex items-center space-x-3 text-slate-600 transition-colors duration-300">
                  <div class="w-2 h-2 bg-gradient-to-r from-teal-500 to-orange-500 rounded-full"></div>
                  <span class="font-medium text-sm md:text-base">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
