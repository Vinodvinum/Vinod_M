---
import { completedProjects } from '../../data/projects';
import type { ProjectCategory } from '../../data/projects';

const categorySections: Array<{ id: ProjectCategory; description: string }> = [
  {
    id: 'Analytics & Dashboards',
    description: 'Data and KPI-focused products, dashboards, and reporting apps.'
  },
  {
    id: 'Websites & Platforms',
    description: 'Full websites and deployed product platforms.'
  },
  {
    id: 'AI Automation & Chatbots',
    description: 'Conversational and workflow automation projects.'
  },
  {
    id: 'Utilities & Media',
    description: 'Utility-focused tools and media-oriented projects.'
  },
  {
    id: 'Computer Vision',
    description: 'Vision and detection systems built with ML pipelines.'
  }
];

const getProjectsByCategory = (category: ProjectCategory) => completedProjects.filter((project) => project.category === category);
---

<section id="projects" class="py-24 md:py-32 px-4 md:px-6 relative z-10 bg-gradient-to-b from-white/5 to-transparent backdrop-blur-sm">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-14 md:mb-24">
      <h2 class="text-4xl md:text-6xl font-black gradient-text mb-5 md:mb-6">Projects</h2>
      <p class="text-base md:text-2xl text-white/80 max-w-2xl mx-auto leading-relaxed px-2">
        Live deployments, source code, and ongoing work
      </p>
      <div class="w-20 md:w-24 h-1 mx-auto mt-6 md:mt-8 bg-gradient-to-r from-purple-400 to-pink-400 rounded-full"></div>
    </div>

    {categorySections.map((section) => {
      const projects = getProjectsByCategory(section.id);

      if (projects.length === 0) {
        return null;
      }

      return (
        <div class="mb-14 md:mb-20 last:mb-0">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 md:gap-4 mb-6 md:mb-8">
            <div>
              <h3 class="text-2xl md:text-4xl font-black text-white mb-2">{section.id}</h3>
              <p class="text-white/70 text-sm md:text-lg max-w-2xl leading-relaxed">{section.description}</p>
            </div>
            <div class="w-20 h-1 bg-gradient-to-r from-purple-400 to-pink-400 rounded-full"></div>
          </div>

          <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5 md:gap-8">
            {projects.map((project) => (
              <article class="group glass rounded-3xl p-4 md:p-6 hover:scale-[1.03] hover:shadow-[0_25px_50px_rgba(0,0,0,0.5)] hover:shadow-purple-500/20 transition-all duration-500 shadow-2xl border-white/10 overflow-hidden">
                <div class={`relative overflow-hidden rounded-2xl h-44 mb-6 bg-gradient-to-br ${project.accent} border border-white/10`}>
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.22),transparent_42%)]"></div>
                  <div class="relative h-full p-5 flex items-end justify-between">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/75 mb-2">{project.platform}</p>
                      <div class="text-5xl font-black text-white/95 leading-none">{project.monogram}</div>
                    </div>
                    <span class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold bg-white/15 text-white/90 border border-white/20 backdrop-blur-sm">
                      {project.status}
                    </span>
                  </div>
                </div>

                <div class="flex items-start justify-between gap-4 mb-4">
                  <h4 class="text-xl md:text-2xl font-bold text-white leading-tight">{project.title}</h4>
                </div>

                <p class="text-white/80 leading-relaxed text-sm md:text-base">{project.description}</p>

                <div class="flex flex-wrap gap-2 mt-6">
                  {project.tags.map((tag) => (
                    <span class="px-3 py-1 bg-white/10 backdrop-blur-sm rounded-lg text-xs font-semibold text-white/90 border border-white/20 hover:bg-white/20 transition-all duration-300">
                      {tag}
                    </span>
                  ))}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-7">
                  {project.liveUrl && (
                    <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="gradient-border glass px-4 py-3 rounded-2xl font-semibold text-sm hover:scale-105 transition-all duration-300 text-center">
                      Live Demo
                    </a>
                  )}
                  {project.githubUrl && (
                    <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-white/90 hover:text-white hover:bg-white/10 border border-white/30 hover:scale-105 transition-all duration-300 text-center">
                      GitHub
                    </a>
                  )}
                  {project.publicationUrl && (
                    <a href={project.publicationUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-cyan-100 hover:text-white hover:bg-cyan-500/20 border border-cyan-300/40 hover:scale-105 transition-all duration-300 text-center">
                      Publication
                    </a>
                  )}
                  {project.certificateUrl && (
                    <a href={project.certificateUrl} target="_blank" rel="noopener noreferrer" class="glass px-4 py-3 rounded-2xl font-semibold text-sm text-emerald-100 hover:text-white hover:bg-emerald-500/20 border border-emerald-300/40 hover:scale-105 transition-all duration-300 text-center">
                      Certificate
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>