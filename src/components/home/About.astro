---
import { completedProjects, ongoingProjects } from '../../data/projects';
import { socialLinks } from '../../data/social-links';

const totalProjects = completedProjects.length + ongoingProjects.length;
---

<section id="about" class="py-32 px-6 relative z-10">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-24">
      <h2 class="text-5xl md:text-6xl font-black gradient-text mb-6">About Me</h2>
      <div class="w-24 h-1 mx-auto bg-gradient-to-r from-purple-400 to-pink-400 rounded-full"></div>
    </div>

    <!-- Content -->
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left: Image/Stats -->
      <div class="relative order-2 md:order-1">
        <div class="glass rounded-3xl p-8 md:p-12 shadow-2xl shadow-black/20 border-white/10 max-w-md mx-auto md:ml-auto">
          <div class="text-center mb-8">
            <div class="w-28 h-28 mx-auto mb-6 glass rounded-3xl p-5 shadow-2xl border-4 border-white/20">
              <img src="/images/profile.jpg" alt="Vinod M, also known as Vinu, from Mysuru, Karnataka" class="w-full h-full rounded-2xl object-cover" />
            </div>
            <h3 class="text-3xl font-bold gradient-text mb-2">Vinod M</h3>
            <p class="text-xl text-white/80">AI, Data Analytics & Software Engineering</p>
          </div>
          
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-3xl font-black gradient-text">{totalProjects}+</div>
              <div class="text-white/70 text-sm uppercase tracking-wide">Projects</div>
            </div>
            <div>
              <div class="text-3xl font-black gradient-text">1</div>
              <div class="text-white/70 text-sm uppercase tracking-wide">Publication</div>
            </div>
            <div>
              <div class="text-3xl font-black gradient-text">MCA</div>
              <div class="text-white/70 text-sm uppercase tracking-wide">Graduate</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Bio -->
      <div class="order-1 md:order-2 space-y-6 max-w-xl">
        <p class="text-xl md:text-2xl text-white/90 leading-relaxed">
          I am <span class="gradient-text font-semibold">Vinod M</span>, based in Hootgalli, Mysuru. I build data, BI, and AI solutions for real business problems.
        </p>

        <p class="text-lg md:text-xl text-white/80 leading-relaxed">
          My work sits at the intersection of analytics, automation, and software delivery. I turn messy data or vague requirements into something teams can use.
        </p>

        <div class="glass p-6 rounded-2xl border border-blue-300/30 bg-blue-500/10">
          <p class="text-base md:text-lg text-blue-100 leading-relaxed font-medium">
            Research publication: <strong>IJIRCCE</strong> paper on computer vision for object detection, tracking, and speed estimation.
          </p>
        </div>

        <div class="glass p-6 rounded-2xl border border-emerald-300/30 bg-emerald-500/10">
          <p class="text-base md:text-lg text-emerald-100 leading-relaxed font-medium">
            I help build products with <strong>Medhaksha Technology</strong>.
            <a href="https://medhakshatech.in/" target="_blank" rel="noopener noreferrer" class="ml-2 text-emerald-300 hover:text-white underline underline-offset-4 transition-colors duration-300">
              medhakshatech.in
            </a>
          </p>
        </div>

        <div class="glass p-8 rounded-3xl border-white/10">
          <p class="text-lg text-white/90 italic font-medium">
            "I like work that is simple to understand, useful in practice, and strong enough to ship."
          </p>
        </div>

        <div class="glass p-6 rounded-2xl border border-purple-300/30 bg-purple-500/10">
          <p class="text-base md:text-lg text-purple-100 leading-relaxed font-medium">
            <strong>Currently learning:</strong> deeper SQL modeling, dashboard design, and AI workflows that are easier to maintain.
          </p>
        </div>

        <div class="glass p-6 rounded-2xl border border-white/10">
          <p class="text-base md:text-lg text-white/80 leading-relaxed font-medium">
            Find me on <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="text-cyan-200 hover:text-white underline underline-offset-4">GitHub</a>, <a href={socialLinks.githubReadme} target="_blank" rel="noopener noreferrer" class="text-cyan-200 hover:text-white underline underline-offset-4">my profile README</a>, and <a href={socialLinks.linkedin} target="_blank" rel="noopener noreferrer" class="text-cyan-200 hover:text-white underline underline-offset-4">LinkedIn</a>.
          </p>
        </div>

        <p class="text-lg md:text-xl text-white/80 leading-relaxed">
          I’m open to roles in <strong>Data Analytics, Business Intelligence, AI, and Software Engineering</strong> where the work is hands-on and practical.
        </p>
      </div>
    </div>
  </div>
</section>