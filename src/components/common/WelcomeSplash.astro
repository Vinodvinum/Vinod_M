<section id="welcome-splash" class="fixed inset-0 z-[120] overflow-hidden bg-[#020617]">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(56,189,248,0.18),transparent_24%),radial-gradient(circle_at_80%_18%,rgba(217,70,239,0.16),transparent_26%),radial-gradient(circle_at_50%_72%,rgba(99,102,241,0.16),transparent_32%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.65),rgba(2,6,23,0.94))]"></div>

  <div id="welcome-stars" class="absolute inset-0" aria-hidden="true"></div>
  <canvas id="welcome-comet-canvas" class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

  <button
    id="welcome-skip"
    type="button"
    class="absolute right-4 top-4 md:right-6 md:top-6 z-20 rounded-full border border-white/20 bg-slate-950/45 px-4 py-2 text-xs md:text-sm font-semibold uppercase tracking-[0.25em] text-white/80 backdrop-blur-md transition-all duration-300 hover:bg-white/10 hover:text-white"
  >
    Skip
  </button>

  <div class="absolute inset-0 z-10 flex items-center justify-center px-6">
    <div class="relative w-full max-w-5xl text-center">
      <div id="welcome-centerpiece" class="pointer-events-none relative mx-auto h-60 w-60 opacity-0 scale-75 md:h-72 md:w-72">
        <div class="welcome-aura welcome-aura-primary"></div>
        <div class="welcome-aura welcome-aura-secondary"></div>
        <div id="welcome-burst" class="welcome-burst"></div>
        <div class="welcome-form">
          <span class="welcome-form__halo"></span>
          <span class="welcome-form__crown"></span>
          <span class="welcome-form__head"></span>
          <span class="welcome-form__torso"></span>
          <span class="welcome-form__arms"></span>
          <span class="welcome-form__seat"></span>
        </div>
      </div>

      <div id="welcome-copy" class="mx-auto mt-10 max-w-4xl opacity-0">
        <p class="mb-3 text-[11px] md:text-sm font-semibold uppercase tracking-[0.4em] text-cyan-200/80">
          Cosmic Intelligence
        </p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white drop-shadow-[0_0_24px_rgba(96,165,250,0.25)]">
          Vinod M
        </h1>
        <p class="mt-4 text-sm md:text-xl lg:text-2xl font-medium text-white/85 leading-relaxed">
          AI Engineer | Building Intelligent Systems | Data Scientist | Data Analyst
        </p>
        <p class="mt-3 text-sm md:text-lg text-fuchsia-200/80 italic">
          Tat Tvam Asi
        </p>
        <p class="mt-2 text-xs md:text-base text-cyan-100/70">
          From Cosmic Energy to Artificial Intelligence
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .welcome-aura {
    position: absolute;
    inset: 50%;
    border-radius: 9999px;
    transform: translate(-50%, -50%);
    filter: blur(12px);
    opacity: 0.7;
  }

  .welcome-aura-primary {
    width: 14rem;
    height: 14rem;
    background:
      radial-gradient(circle, rgba(34, 211, 238, 0.26) 0%, rgba(59, 130, 246, 0.14) 38%, transparent 72%);
    animation: welcomePulse 2.4s ease-in-out infinite;
  }

  .welcome-aura-secondary {
    width: 18rem;
    height: 18rem;
    background:
      radial-gradient(circle, rgba(217, 70, 239, 0.2) 0%, rgba(99, 102, 241, 0.12) 42%, transparent 74%);
    animation: welcomePulse 3.1s ease-in-out infinite reverse;
  }

  .welcome-burst {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    transform: translate(-50%, -50%) scale(0.2);
    background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(96,165,250,0.65) 30%, rgba(217,70,239,0.3) 55%, transparent 72%);
    filter: blur(1px);
    opacity: 0;
  }

  .welcome-form {
    position: absolute;
    inset: 50%;
    width: 12rem;
    height: 12rem;
    transform: translate(-50%, -50%);
  }

  .welcome-form span {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: block;
  }

  .welcome-form__halo {
    top: 0.2rem;
    width: 8rem;
    height: 8rem;
    border-radius: 9999px;
    border: 1px solid rgba(125, 211, 252, 0.5);
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.35), inset 0 0 20px rgba(217, 70, 239, 0.18);
    background: radial-gradient(circle, rgba(255,255,255,0.08), transparent 70%);
  }

  .welcome-form__crown {
    top: 2.2rem;
    width: 4.8rem;
    height: 1.8rem;
    border-radius: 9999px;
    background: linear-gradient(90deg, rgba(34,211,238,0.18), rgba(255,255,255,0.55), rgba(217,70,239,0.22));
    filter: blur(0.5px);
  }

  .welcome-form__head {
    top: 3.3rem;
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 9999px;
    background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.95), rgba(125,211,252,0.68) 45%, rgba(99,102,241,0.42) 72%, rgba(2,6,23,0.1) 100%);
    box-shadow: 0 0 28px rgba(96, 165, 250, 0.42);
  }

  .welcome-form__torso {
    top: 6.5rem;
    width: 6rem;
    height: 5.6rem;
    border-radius: 46% 46% 40% 40%;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.82), rgba(99,102,241,0.46) 42%, rgba(14,165,233,0.22) 76%, transparent 100%);
    box-shadow: 0 0 28px rgba(167, 139, 250, 0.24);
    filter: blur(0.2px);
  }

  .welcome-form__arms {
    top: 7.5rem;
    width: 10rem;
    height: 3.4rem;
    border-radius: 9999px;
    background:
      radial-gradient(circle at 12% 50%, rgba(34,211,238,0.75), transparent 22%),
      radial-gradient(circle at 88% 50%, rgba(217,70,239,0.72), transparent 22%),
      linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.32) 16%, rgba(125,211,252,0.42) 50%, rgba(255,255,255,0.28) 84%, transparent 100%);
    filter: blur(1px);
    opacity: 0.88;
  }

  .welcome-form__seat {
    top: 10.8rem;
    width: 8rem;
    height: 2.5rem;
    border-radius: 9999px;
    background:
      radial-gradient(circle at 50% 35%, rgba(255,255,255,0.65), rgba(34,211,238,0.25) 35%, rgba(217,70,239,0.18) 72%, transparent 100%);
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.24);
  }

  @keyframes welcomePulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(0.96);
      opacity: 0.6;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.06);
      opacity: 0.92;
    }
  }
</style>

<script>
  const splash = document.getElementById('welcome-splash');

  if (splash) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hasSeenSplash = sessionStorage.getItem('vinod-welcome-seen') === '1';
    const homeTargets = ['nav', 'main', 'footer', '#particles', 'a[aria-label="Chat on WhatsApp"]'];

    const clearPageState = () => {
      homeTargets.forEach((selector) => {
        const element = document.querySelector(selector);
        if (element instanceof HTMLElement) {
          element.style.opacity = '';
          element.style.transform = '';
          element.style.filter = '';
          element.style.transformOrigin = '';
        }
      });
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
    };

    if (hasSeenSplash) {
      splash.remove();
      clearPageState();
    } else {
      void (async () => {
        const [{ default: gsap }, THREE] = await Promise.all([
          import('gsap'),
          import('three')
        ]);

        const restorePage = () => {
          gsap.set(homeTargets, {
            clearProps: 'all'
          });
          document.documentElement.style.overflow = '';
          document.body.style.overflow = '';
        };

        gsap.set(homeTargets, {
          opacity: 0.55,
          scale: 0.985,
          filter: 'blur(10px)',
          transformOrigin: 'center top'
        });

        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';

        const skipButton = document.getElementById('welcome-skip');
        const starsHost = document.getElementById('welcome-stars');
        const cometCanvas = document.getElementById('welcome-comet-canvas');
        const centerpiece = document.getElementById('welcome-centerpiece');
        const burstEl = document.getElementById('welcome-burst');
        const copyEl = document.getElementById('welcome-copy');

        let rafId = 0;
        let renderer;
        let scene;
        let camera;
        let starField;
        let active = true;
        let timeline;
        const trail = [];
        const sparks = [];
        const cometState = { progress: 0, burst: 0, flash: 0 };
        const maxTrail = 34;

        const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
        const ctx = cometCanvas?.getContext('2d');

        const setCanvasSize = () => {
          if (!starsHost || !cometCanvas) return;
          const width = window.innerWidth;
          const height = window.innerHeight;
          cometCanvas.width = Math.floor(width * dpr);
          cometCanvas.height = Math.floor(height * dpr);
          cometCanvas.style.width = `${width}px`;
          cometCanvas.style.height = `${height}px`;
          ctx?.setTransform(dpr, 0, 0, dpr, 0, 0);

          if (renderer && camera) {
            renderer.setSize(width, height, false);
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
          }
        };

        const cubicPoint = (t, p0, p1, p2, p3) => {
          const mt = 1 - t;
          return (
            mt * mt * mt * p0 +
            3 * mt * mt * t * p1 +
            3 * mt * t * t * p2 +
            t * t * t * p3
          );
        };

        const cometPosition = (progress) => {
          const width = window.innerWidth;
          const height = window.innerHeight;
          return {
            x: cubicPoint(progress, width * -0.14, width * 0.14, width * 0.4, width * 0.5),
            y: cubicPoint(progress, height * 0.28, height * 0.06, height * 0.16, height * 0.42)
          };
        };

        const addSparkBurst = (origin) => {
          sparks.length = 0;
          for (let i = 0; i < 22; i += 1) {
            const angle = (Math.PI * 2 * i) / 22 + Math.random() * 0.25;
            const velocity = 2.4 + Math.random() * 2.4;
            sparks.push({
              x: origin.x,
              y: origin.y,
              vx: Math.cos(angle) * velocity,
              vy: Math.sin(angle) * velocity,
              life: 1,
              radius: 1.2 + Math.random() * 2.4
            });
          }
        };

        const drawComet = () => {
          if (!ctx || !cometCanvas) return;
          const width = window.innerWidth;
          const height = window.innerHeight;

          ctx.clearRect(0, 0, width, height);

          trail.forEach((point, index) => {
            const alpha = (index + 1) / trail.length;
            ctx.beginPath();
            ctx.fillStyle = `rgba(125, 211, 252, ${alpha * 0.17})`;
            ctx.arc(point.x, point.y, 1.5 + alpha * 9, 0, Math.PI * 2);
            ctx.fill();
          });

          sparks.forEach((spark) => {
            ctx.beginPath();
            ctx.fillStyle = `rgba(255, 255, 255, ${spark.life * 0.95})`;
            ctx.arc(spark.x, spark.y, spark.radius, 0, Math.PI * 2);
            ctx.fill();
            spark.x += spark.vx;
            spark.y += spark.vy;
            spark.vx *= 0.985;
            spark.vy *= 0.985;
            spark.life *= 0.94;
          });

          for (let i = sparks.length - 1; i >= 0; i -= 1) {
            if (sparks[i].life < 0.06) sparks.splice(i, 1);
          }

          if (cometState.progress < 1) {
            const point = cometPosition(cometState.progress);
            trail.push(point);
            if (trail.length > maxTrail) trail.shift();

            const glow = ctx.createRadialGradient(point.x, point.y, 0, point.x, point.y, 36);
            glow.addColorStop(0, 'rgba(255,255,255,0.95)');
            glow.addColorStop(0.18, 'rgba(125,211,252,0.95)');
            glow.addColorStop(0.5, 'rgba(59,130,246,0.4)');
            glow.addColorStop(1, 'rgba(59,130,246,0)');
            ctx.beginPath();
            ctx.fillStyle = glow;
            ctx.arc(point.x, point.y, 36, 0, Math.PI * 2);
            ctx.fill();

            ctx.beginPath();
            ctx.fillStyle = 'rgba(255,255,255,0.98)';
            ctx.arc(point.x, point.y, 6.5, 0, Math.PI * 2);
            ctx.fill();
          } else if (trail.length) {
            trail.shift();
          }

          if (cometState.flash > 0) {
            ctx.fillStyle = `rgba(255,255,255,${cometState.flash * 0.12})`;
            ctx.fillRect(0, 0, width, height);
          }
        };

        const initStars = () => {
          if (!starsHost) return;

          scene = new THREE.Scene();
          camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 1000);
          camera.position.z = 210;

          renderer = new THREE.WebGLRenderer({
            alpha: true,
            antialias: false,
            powerPreference: 'low-power'
          });
          renderer.setPixelRatio(dpr);
          renderer.setSize(window.innerWidth, window.innerHeight, false);
          starsHost.appendChild(renderer.domElement);

          const starCount = window.innerWidth < 768 ? 220 : 360;
          const positions = new Float32Array(starCount * 3);
          for (let i = 0; i < starCount; i += 1) {
            positions[i * 3] = (Math.random() - 0.5) * 420;
            positions[i * 3 + 1] = (Math.random() - 0.5) * 260;
            positions[i * 3 + 2] = (Math.random() - 0.5) * 220;
          }

          const geometry = new THREE.BufferGeometry();
          geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
          const material = new THREE.PointsMaterial({
            color: 0xdbeafe,
            size: window.innerWidth < 768 ? 1.35 : 1.8,
            transparent: true,
            opacity: 0,
            depthWrite: false
          });

          starField = new THREE.Points(geometry, material);
          scene.add(starField);

          gsap.to(material, {
            opacity: 0.9,
            duration: prefersReducedMotion ? 0.3 : 0.9,
            ease: 'power1.out'
          });
        };

        const animate = () => {
          if (!active) return;
          drawComet();

          if (starField && renderer && scene && camera) {
            starField.rotation.z += 0.00035;
            starField.rotation.y += 0.00018;
            renderer.render(scene, camera);
          }

          rafId = window.requestAnimationFrame(animate);
        };

        const cleanup = () => {
          active = false;
          window.cancelAnimationFrame(rafId);
          window.removeEventListener('resize', onResize);
          timeline?.kill();

          if (renderer) {
            renderer.dispose();
            renderer.domElement.remove();
          }

          if (starField) {
            starField.geometry.dispose();
            starField.material.dispose();
          }

          restorePage();
          splash.remove();
        };

        const finishSplash = (immediate = false) => {
          sessionStorage.setItem('vinod-welcome-seen', '1');

          if (immediate) {
            cleanup();
            return;
          }

          gsap.timeline({
            onComplete: cleanup
          })
            .to(copyEl, {
              y: -18,
              opacity: 0,
              duration: 0.32,
              ease: 'power2.in'
            }, 0)
            .to(centerpiece, {
              scale: 1.08,
              opacity: 0,
              duration: 0.36,
              ease: 'power2.in'
            }, 0)
            .to(homeTargets, {
              opacity: 1,
              scale: 1,
              filter: 'blur(0px)',
              duration: 0.55,
              ease: 'power2.out'
            }, 0)
            .to(splash, {
              opacity: 0,
              duration: 0.48,
              ease: 'power2.out'
            }, 0.05);
        };

        const onResize = () => setCanvasSize();

        initStars();
        setCanvasSize();
        animate();
        window.addEventListener('resize', onResize);

        gsap.set([centerpiece, copyEl], { willChange: 'transform, opacity' });

        timeline = gsap.timeline({
          defaults: { ease: 'power2.out' },
          onComplete: () => finishSplash(false)
        });

        if (prefersReducedMotion) {
          timeline
            .to(centerpiece, { opacity: 1, scale: 1, duration: 0.25 }, 0)
            .to(copyEl, { opacity: 1, y: 0, duration: 0.3 }, 0.15)
            .to({}, { duration: 0.8 }, 0.2);
        } else {
          timeline
            .to(cometState, {
              progress: 1,
              duration: 1.12,
              ease: 'power2.inOut',
              onComplete: () => {
                const impactPoint = cometPosition(1);
                addSparkBurst(impactPoint);
                gsap.fromTo(
                  burstEl,
                  { opacity: 0.95, scale: 0.1 },
                  { opacity: 0, scale: 5.8, duration: 0.65, ease: 'power3.out' }
                );
                gsap.fromTo(
                  cometState,
                  { flash: 1 },
                  { flash: 0, duration: 0.55, ease: 'power2.out' }
                );
              }
            }, 0.72)
            .to(centerpiece, {
              opacity: 1,
              scale: 1,
              duration: 0.7,
              ease: 'back.out(1.2)'
            }, 1.6)
            .fromTo(
              '#welcome-copy > *',
              { opacity: 0, y: 20 },
              { opacity: 1, y: 0, duration: 0.72, stagger: 0.11, ease: 'power2.out' },
              2.18
            )
            .to({}, { duration: 1 }, 3.15);
        }

        skipButton?.addEventListener('click', () => finishSplash(true), { once: true });
      })();
    }
  }
</script>
