---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { navItems } from '../data/nav';
import { socialLinks } from '../data/social-links';
import { routeLabels } from '../data/seo';
import { absoluteUrl, buildBreadcrumbSchema, buildOrganizationSchema, buildPersonSchema, buildWebsiteSchema, schemaToJson, siteConfig } from '../utils/seo';
import '../styles/global.css';
import '../styles/animations.css';

const {
  title = 'Vinod M | AI, Data Analytics, and Software Engineering',
  description = 'Vinod M, also known as Vinu, is a technology professional from Mysuru, Karnataka building AI, analytics, automation, and software projects.',
  canonical,
  ogImage = '/images/profile.jpg',
  pageType = 'website',
  extraSchemas = [],
} = Astro.props;

const pathname = Astro.url.pathname || '/';
const siteUrl = canonical ?? absoluteUrl(pathname);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : absoluteUrl(ogImage);
const keywordSet = [...siteConfig.commonNames, 'Mysuru', 'AI', 'Machine Learning', 'Data Analytics', 'Power BI', 'SQL', 'Python', 'Generative AI'];
const segments = pathname.split('/').filter(Boolean);
const breadcrumbs = segments.length === 0
  ? []
  : [
      { name: 'Home', item: absoluteUrl('/') },
      ...segments.map((segment, index) => {
        const currentPath = `/${segments.slice(0, index + 1).join('/')}`;
        return {
          name: routeLabels[currentPath] ?? decodeURIComponent(segment).replace(/-/g, ' '),
          item: absoluteUrl(currentPath),
        };
      }),
    ];

const baseSchemas = [
  buildWebsiteSchema(title, description, pathname),
  buildPersonSchema(description, pathname),
  buildOrganizationSchema(description, pathname),
  ...(breadcrumbs.length > 1 ? [buildBreadcrumbSchema(breadcrumbs)] : []),
  ...extraSchemas,
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="keywords" content={keywordSet.join(', ')} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={siteUrl} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#020617" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Vinod M" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/jpg+xml" href="/images/profile.jpg" />
    <link rel="apple-touch-icon" href="/images/profile.jpg" />
    
    <!-- Global Script -->
    <script src="/scripts/global.js" is:inline></script>
    
    <ClientRouter />

    {baseSchemas.map((schema) => (
      <script type="application/ld+json" set:html={schemaToJson(schema)} />
    ))}
  </head>
  <body class="relative min-h-screen">
    <!-- Particles Container -->
    <div id="particles" class="fixed inset-0 pointer-events-none z-0"></div>
    
    <Navbar {navItems} />
    <main id="main">
      <slot />
    </main>
    <Footer {socialLinks} />

    <!-- 📱 WHATSAPP FLOATING BUTTON -->
     <a href={`https://wa.me/${socialLinks.whatsapp}`} class="fixed bottom-8 right-8 z-50 glass w-16 h-16 rounded-3xl shadow-2xl hover:scale-110 transition-all duration-300 group flex items-center justify-center text-3xl" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      💬
    </a>
    
    <script>
      // Mobile Menu Toggle
      document.addEventListener('DOMContentLoaded', () => {
        const mobileBtn = document.getElementById('mobile-menu');
        const mobileMenu = document.getElementById('mobile-menu-items');
        
        if (mobileBtn && mobileMenu) {
          mobileBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>